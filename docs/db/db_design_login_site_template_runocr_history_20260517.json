        "INDEX(site_id, run_id)",
        "GIN(document_fields)",
        "GIN(normalized_fields)"
      ],
      "preprocessingDebugPolicy": "debugPreprocessing=true OR productionApplied=true 시에만 저장"
    },
    {
      "name": "ocr_run_table_rows",
      "priority": "P3",
      "purpose": "거래명세서 등 표 row 단위 정규화 저장.",
      "screens": ["History detail (행 단위 편집/검색)"],
      "siteScoped": true,
      "columns": [
        { "name": "id", "type": "UUID", "required": true, "primaryKey": true },
        { "name": "site_id", "type": "UUID", "required": true, "foreignKey": "sites.id" },
        { "name": "result_id", "type": "UUID", "required": true, "foreignKey": "ocr_run_results.id", "notes": "ON DELETE CASCADE" },
        { "name": "row_index", "type": "INTEGER", "required": true, "purpose": "0-based" },
        { "name": "row_data", "type": "JSONB", "required": true, "purpose": "컬럼명→값" },
        { "name": "source_bboxes", "type": "JSONB", "required": false, "purpose": "셀별 bbox" },
        { "name": "confidence", "type": "NUMERIC(5,4)", "required": false },
        { "name": "row_status", "type": "VARCHAR(16)", "required": false, "purpose": "auto/reviewed/corrected/rejected" },
        { "name": "metadata", "type": "JSONB", "required": false },
        { "name": "created_at", "type": "TIMESTAMPTZ", "required": true }
      ],
      "indexes": ["INDEX(result_id, row_index)"],
      "notes": "MVP는 ocr_run_results.document_fields.tableRows JSONB로 충분. 행 단위 검색/편집 요구 시 도입."
    },
    {
      "name": "ocr_run_warnings",
      "priority": "P3",
      "purpose": "OCR/파서/전처리 경고 누적 저장.",
      "screens": ["Quality dashboard", "History detail warnings panel"],
      "siteScoped": true,
      "columns": [
        { "name": "id", "type": "UUID", "required": true, "primaryKey": true },
        { "name": "site_id", "type": "UUID", "required": true, "foreignKey": "sites.id" },
        { "name": "result_id", "type": "UUID", "required": true, "foreignKey": "ocr_run_results.id" },
        { "name": "warning_type", "type": "VARCHAR(64)", "required": true, "purpose": "value_mapping/source_missing/preprocessing/parser" },
        { "name": "field_key", "type": "VARCHAR(64)", "required": false },
        { "name": "severity", "type": "VARCHAR(16)", "required": true, "purpose": "info/warning/error" },
        { "name": "message", "type": "TEXT", "required": true },
        { "name": "metadata", "type": "JSONB", "required": false },
        { "name": "created_at", "type": "TIMESTAMPTZ", "required": true }
      ],
      "indexes": ["INDEX(result_id, severity)", "INDEX(site_id, warning_type, created_at)"],
      "notes": "MVP는 ocr_run_results.warnings_summary JSONB로 충분."
    },
    {
      "name": "user_preferences",
      "priority": "P2",
      "purpose": "사용자별 UI/운영 환경 설정.",
      "screens": ["All screens (theme, last_site, default_options)"],
      "siteScoped": false,
      "replaces": ["localStorage mysuit_ocr_theme", "localStorage mysuit_ocr_login (선택)"],
      "columns": [
        { "name": "id", "type": "UUID", "required": true, "primaryKey": true },
        { "name": "user_id", "type": "UUID", "required": true, "foreignKey": "users.id" },
        { "name": "preference_key", "type": "VARCHAR(64)", "required": true, "purpose": "theme/last_site_id/default_options" },
        { "name": "preference_value", "type": "JSONB", "required": true },
        { "name": "created_at", "type": "TIMESTAMPTZ", "required": true },
        { "name": "updated_at", "type": "TIMESTAMPTZ", "required": true }
      ],
      "indexes": ["UNIQUE(user_id, preference_key)"]
    },
    {
      "name": "audit_logs",
      "priority": "P2",
      "purpose": "운영/감사 이벤트 로그. review_log.jsonl 대체 및 확장.",
      "screens": ["Admin dashboard", "Security audit"],
      "siteScoped": "nullable",
      "replaces": ["ocr-server/data/review_log.jsonl (확장)"],
      "columns": [
        { "name": "id", "type": "BIGSERIAL", "required": true, "primaryKey": true, "purpose": "대량 append 고려" },
        { "name": "site_id", "type": "UUID", "required": false, "foreignKey": "sites.id" },
        { "name": "user_id", "type": "UUID", "required": false, "foreignKey": "users.id" },
        { "name": "action", "type": "VARCHAR(64)", "required": true, "purpose": "auth.login, template.create, run.execute 등" },
        { "name": "entity_type", "type": "VARCHAR(64)", "required": false },
        { "name": "entity_id", "type": "UUID", "required": false },
        { "name": "ip_address", "type": "INET", "required": false },
        { "name": "user_agent", "type": "TEXT", "required": false },
        { "name": "metadata", "type": "JSONB", "required": false, "purpose": "before/after, reason" },
        { "name": "created_at", "type": "TIMESTAMPTZ", "required": true }
      ],
      "indexes": ["INDEX(site_id, created_at DESC)", "INDEX(user_id, created_at DESC)", "INDEX(action, created_at DESC)"]
    }
  ],
  "screenMappings": [
