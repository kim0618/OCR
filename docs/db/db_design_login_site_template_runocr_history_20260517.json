  ],
  "apiSurface": {
    "auth": [
      "POST /auth/login",
      "POST /auth/logout",
      "GET /auth/me"
    ],
    "sites": [
      "GET /sites",
      "POST /sites",
      "GET /sites/:siteId",
      "PATCH /sites/:siteId",
      "GET /sites/:siteId/members",
      "POST /sites/:siteId/members",
      "PATCH /sites/:siteId/members/:memberId",
      "DELETE /sites/:siteId/members/:memberId"
    ],
    "templates": [
      "GET /sites/:siteId/templates",
      "POST /sites/:siteId/templates",
      "GET /sites/:siteId/templates/:templateId",
      "PUT /sites/:siteId/templates/:templateId",
      "DELETE /sites/:siteId/templates/:templateId"
    ],
    "runocr": [
      "POST /sites/:siteId/ocr/runs",
      "GET /sites/:siteId/ocr/runs/:runId",
      "GET /sites/:siteId/ocr/runs/:runId/files",
      "GET /sites/:siteId/ocr/runs/:runId/results"
    ],
    "history": [
      "GET /sites/:siteId/history",
      "GET /sites/:siteId/history/:runId",
      "DELETE /sites/:siteId/history/:runId"
    ]
  },
  "permissions": {
    "global": {
      "super_admin": "Bypass all site checks. Manage all users/sites/data."
    },
    "site": {
      "owner": ["site.manage_members", "site.manage_settings", "template.*", "run.*", "history.*"],
      "admin": ["site.manage_members(non-owner)", "template.*", "run.*", "history.*"],
      "member": ["template.use", "run.execute", "history.read(own+public)", "history.delete(own)"],
      "viewer": ["history.read"]
    }
  },
  "decisions": [
    {
      "id": "D1",
      "topic": "Template regions/guides 정규화 시점",
      "recommendation": "MVP는 template_body JSONB. P2에서 사용 패턴 보고 정규화",
      "alternatives": ["즉시 정규화"],
      "impact": "MVP 출시 속도 vs 영역 단위 분석 유연성"
    },
    {
      "id": "D2",
      "topic": "비밀번호 저장 방식",
      "recommendation": "bcrypt cost=12, VARCHAR(60)",
      "alternatives": ["argon2id", "pbkdf2"],
      "impact": "bcrypt가 라이브러리 호환성 우수"
    },
    {
      "id": "D3",
      "topic": "세션 토큰 저장 방식",
      "recommendation": "SHA-256 해시 저장, 평문 토큰은 클라이언트만",
      "alternatives": ["평문 저장", "JWT"],
      "impact": "해시가 가장 안전. JWT는 강제 만료 어려움"
    },
    {
      "id": "D4",
      "topic": "super_admin 표현",
      "recommendation": "users.is_super_admin BOOLEAN 단일 플래그",
      "alternatives": ["별도 role 테이블"],
      "impact": "플래그 방식이 단순"
    },
    {
      "id": "D5",
      "topic": "run-file-result 관계",
      "recommendation": "1 run → N files → 1:1 result",
      "alternatives": ["1 file → N results (재처리 이력)"],
      "impact": "MVP는 1:1. 재처리는 새 run으로"
    },
    {
      "id": "D6",
      "topic": "preprocessing_debug 저장 시점",
      "recommendation": "debugPreprocessing=true OR productionApplied=true",
      "alternatives": ["항상 저장", "저장 안 함"],
      "impact": "용량 vs 분석"
    },
    {
      "id": "D7",
      "topic": "tableRows 별도 테이블 도입",
      "recommendation": "MVP는 document_fields JSONB. P3에서 분리",
      "alternatives": ["즉시 분리"],
      "impact": "행 단위 검색/편집 요구 발생 시점"
    },
    {
      "id": "D8",
      "topic": "warnings 별도 테이블 도입",
      "recommendation": "MVP는 warnings_summary JSONB. P3에서 분리",
      "alternatives": ["즉시 분리"],
      "impact": "운영 분석 시점"
    },
    {
      "id": "D9",
      "topic": "audit_logs 도입 시점",
      "recommendation": "MVP 직후 P2 즉시",
      "alternatives": ["MVP 포함", "더 후속"],
      "impact": "보안 감사 요구 강도"
    },
    {
      "id": "D10",
      "topic": "user_preferences 도입 시점",
      "recommendation": "P2 (last_site_id 위해)",
      "alternatives": ["localStorage 유지"],
      "impact": "멀티사이트 UX"
    },
    {
      "id": "D11",
      "topic": "sessions.current_site_id 포함 여부",
      "recommendation": "포함 (nullable)",
      "alternatives": ["user_preferences로 분리"],
      "impact": "세션 종료 시 자동 소실 (보안 측면)"
    },
    {
      "id": "D12",
      "topic": "template 버전 관리 방식",
      "recommendation": "update (단순) — version 컬럼은 +1",
      "alternatives": ["insert-new-row (이력 보존)"],
      "impact": "이력 요구 여부에 따라 선택"
    },
    {
      "id": "D13",
      "topic": "storage_key URI scheme",
      "recommendation": "local:// / s3:// 추상화",
      "alternatives": ["단일 경로 문자열"],
      "impact": "스토리지 어댑터 확장성"
    },
    {
      "id": "D14",
      "topic": "document_type CHECK 제약",
      "recommendation": "application-level 검증",
      "alternatives": ["DB CHECK 제약"],
      "impact": "신규 doctype 추가 시 DDL 불필요"
    },
    {
      "id": "D15",
      "topic": "Row-Level Security 즉시 적용",
      "recommendation": "미적용 (application-level)",
      "alternatives": ["즉시 RLS 적용"],
      "impact": "RLS는 디버깅 난이도 높음. 신중히 도입"
    }
  ],
