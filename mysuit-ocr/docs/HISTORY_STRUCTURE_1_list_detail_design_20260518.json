    "history_details.confirmedResult": {
      "ocr_run_results": ["confirmed_fields JSONB", "confirmed_at TIMESTAMPTZ"]
    },
    "mysuit_ocr_restore_profiles": {
      "ocr_restore_profiles": ["id", "site_id", "business_no", "party_type", "fields JSONB", "source_run_id UUID FK", "source_file_name", "created_at", "updated_at"]
