  "restore_profile_relationship": {
    "link_field": "sourceHistoryId → mysuit_ocr_history.job_id",
    "also_links": "sourceFileName → mysuit_ocr_history.file_name",
    "foreign_key_constraint": false,
    "dangling_ref_risk": "History deletion does NOT cascade to restore_profiles — sourceHistoryId becomes dangling reference",
    "reverse_isolation": "Restore profile deletion does NOT affect mysuit_ocr_history",
    "has_restore_profile_flag": "Not in history index — requires runtime lookup from restoreProfileStore"
  },

  "recommended_index_structure": {
    "storage_key": "mysuit_ocr_history_index",
    "fields": {
      "historyId": "string (RUN-XXXXXXXX)",
      "fileName": "string",
      "templateName": "string|null",
      "documentType": "string|null",
      "createdAt": "string",
      "updatedAt": "string (NEW — set on save)",
      "status": "success|fail",
      "processingTime": "number",
      "summary": {
        "fieldCount": "number",
        "autofillStatus": "string",
        "autofillFilledCount": "number",
        "autofillConfirmedCount": "number",
        "primaryBusinessNo": "string|null",
        "primaryCompanyName": "string|null",
        "tableRowCount": "number (future — requires document_fields storage)",
        "warningCount": "number (future)",
        "missingCount": "number (future)"
      },
      "hasConfirmedResult": "boolean",
      "hasRestoreProfile": "boolean (requires sync on restore_profile save/delete)"
    },
    "derivation": {
      "primaryBusinessNo": "autofill_summary.businessNumber",
      "primaryCompanyName": "output_fields 회사명 field modified or original",
      "fieldCount": "output_fields.length",
      "autofillStatus": "autofill_summary.status",
      "hasConfirmedResult": "output_fields.some(f => f.modified !== '')"
    }
  },

  "recommended_detail_structure": {
    "storage_key": "mysuit_ocr_history_details",
    "structure": {
      "historyId": "string",
      "runSnapshot": {
        "description": "Immutable OCR execution data",
        "fields": ["fileName", "templateName", "documentType", "ocrFields", "documentFields", "autofillSummary"]
      },
      "confirmedResult": {
        "description": "Mutable — updated on [저장] click",
        "fields": ["savedAt", "outputFields"]
      },
      "images": {
        "description": "Image URLs (heavy — can be omitted if Quota issues)",
        "fields": ["originalImageUrl", "processedImageUrl", "imageStorageMode"]
      }
    },
    "design_decision_required": {
      "document_fields_tableRows": "Include in runSnapshot.documentFields if History detail needs to show invoice table rows",
      "suggestions_in_outputFields": "output_fields.suggestions[] is heavy — consider stripping before saving to confirmedResult"
    }
  },

  "phase_plan": [
    {
