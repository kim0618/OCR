    "defined_in": "src/lib/historyStore.ts",
    "max_records": 50,
    "record_type": "HistoryRunRecord",
    "fields": {
      "job_id": { "type": "string", "pattern": "RUN-XXXXXXXX", "category": "identifier", "list_needed": true, "detail_needed": true },
      "file_name": { "type": "string", "category": "list_light", "list_needed": true, "detail_needed": true },
      "template_name": { "type": "string|null", "category": "list_light", "list_needed": true, "detail_needed": true },
      "processing_time": { "type": "number", "category": "list_light", "list_needed": true, "detail_needed": false },
      "created_at": { "type": "string", "format": "YYYY-MM-DD HH:mm:ss", "category": "list_light", "list_needed": true, "detail_needed": true },
      "status": { "type": "success|fail", "category": "list_light", "list_needed": true, "detail_needed": false },
      "image_url": { "type": "string?", "category": "image_heavy", "list_needed": false, "detail_needed": true, "note": "legacy" },
      "original_image_url": { "type": "string|null", "category": "image_heavy", "list_needed": false, "detail_needed": true },
      "processed_image_url": { "type": "string|null", "category": "image_heavy", "list_needed": false, "detail_needed": true },
      "image_storage_mode": { "type": "legacy|url", "category": "image_meta", "list_needed": false, "detail_needed": true },
      "ocr_fields": { "type": "HistoryOcrField[]?", "category": "detail_medium", "list_needed": false, "detail_needed": true, "note": "OCR raw fields with bbox" },
      "output_fields": { "type": "HistoryOutputField[]?", "category": "detail_heavy", "list_needed": false, "detail_needed": true, "note": "Heaviest field — includes suggestions[] per field" },
      "autofill_summary": { "type": "HistoryAutofillRunSummary?", "category": "detail_medium", "list_needed": false, "detail_needed": false, "note": "businessNumber useful for list but not currently shown" }
    },
    "missing_fields": {
      "updated_at": "Not tracked — [저장] does not write timestamp",
      "documentType": "Not stored — only template_name exists",
      "primaryBusinessNo": "Not stored — derivable from autofill_summary.businessNumber",
      "primaryCompanyName": "Not stored — derivable from output_fields parsing",
      "hasRestoreProfile": "Not stored — requires restoreProfileStore lookup at runtime",
      "document_fields_tableRows": "CRITICAL: Not stored in history — only available in RunOCR result (OcrResultPanel). History detail CANNOT show invoice table rows.",
      "warningCount": "Not stored — no validation result in history",
      "missingCount": "Not stored"
    },
    "output_field_structure": {
      "type": "HistoryOutputField",
      "heavy_reason": "suggestions[] array contains multiple autofill candidates per field",
      "fields": ["no", "en", "ko", "original", "modified", "confidence", "source", "applied", "autofillAction", "suggestions"]
    }
  },

  "current_list_usage": {
    "component": "src/components/history/HistoryWorkspace.tsx",
    "function": "boardList()",
    "fields_mapped": ["job_id", "file_name", "template_name", "processing_time", "created_at", "status"],
    "fields_loaded_but_unused": ["ocr_fields", "output_fields", "autofill_summary", "image_url", "original_image_url", "processed_image_url"],
    "table_columns_displayed": ["No", "템플릿명", "요청일시", "상태", "파일명", "상세보기", "삭제"],
