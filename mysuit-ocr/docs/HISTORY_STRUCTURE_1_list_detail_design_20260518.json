      "rollback": "Remove index-first branch",
      "validation": ["Old records still show via fallback", "New records show from index with richer fields"]
    },
    {
      "phase": "HISTORY-STRUCTURE-2C",
      "name": "상세 detail 우선 조회",
      "description": "Detail view reads from history_details first, falls back to mysuit_ocr_history",
      "files_to_modify": ["src/components/history/HistoryWorkspace.tsx (detail click)", "src/components/history/DetailHistoryView.tsx"],
      "risk": "medium",
      "rollback": "Remove detail-first branch",
      "validation": ["Fallback works for old records", "Confirmed result shows correctly for new records"]
    },
    {
      "phase": "HISTORY-STRUCTURE-2D",
      "name": "삭제 동기화",
      "description": "deleteHistoryRun() extended to also delete from index and details",
      "files_to_modify": ["src/lib/historyStore.ts"],
      "risk": "medium",
      "rollback": "Remove cascade delete",
      "validation": ["Delete removes from all 3 keys", "No orphan records"]
    },
    {
      "phase": "HISTORY-STRUCTURE-3",
      "name": "DB 전환",
      "description": "Replace historyStore.ts localStorage operations with API calls",
      "files_to_modify": ["src/lib/historyStore.ts (full replacement)"],
      "risk": "high",
      "rollback": "Revert historyStore.ts to localStorage version",
      "validation": ["All CRUD via API", "Pagination", "Filter", "Existing data migration"]
    }
  ],

  "db_mapping": {
    "history_index": {
