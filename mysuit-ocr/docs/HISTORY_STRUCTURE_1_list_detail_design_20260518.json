      "label": "저장",
      "updates": "output_fields (full replacement via updateHistoryRun)",
      "storage": "mysuit_ocr_history",
      "also_updates": "mysuit_ocr_groundtruth",
      "does_not_update": ["updated_at (field missing)", "ocr_fields", "autofill_summary", "images"]
