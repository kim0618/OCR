  },

  "current_detail_usage": {
    "component": "src/components/history/DetailHistoryView.tsx",
    "fields_used": ["job_id", "file_name", "template_name", "created_at", "output_fields", "ocr_fields", "original_image_url", "processed_image_url", "image_url", "image_storage_mode"],
