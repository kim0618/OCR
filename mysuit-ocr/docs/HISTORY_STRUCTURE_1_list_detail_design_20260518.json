  "risks": [
    {
      "id": "R-1",
      "risk": "localStorage 용량 증가",
      "impact": "index + detail 추가로 기존 대비 약 1.5~2배 용량 증가",
      "mitigation": "신규 key에도 MAX_RECORDS=50 동일 적용, QuotaExceededError 폴백 구현 필수"
    },
    {
      "id": "R-2",
      "risk": "index/detail 불일치 (부분 쓰기 실패)",
      "impact": "목록은 있으나 상세 없는 상태 발생 가능",
      "mitigation": "상세 조회 실패 시 mysuit_ocr_history fallback 유지"
    },
    {
      "id": "R-3",
      "risk": "[저장] 후 index.updatedAt 미갱신",
      "impact": "목록에서 최근 수정 시점 오표시",
      "mitigation": "2A-b 단계에서 [저장] → index.updatedAt 갱신 연동"
    },
    {
      "id": "R-4",
      "risk": "삭제 시 orphan detail 레코드",
      "impact": "history_details에 참조되지 않는 레코드 누적",
      "mitigation": "2D 단계에서 deleteHistoryRun() 확장"
    },
    {
      "id": "R-5",
      "risk": "sourceHistoryId dangling reference",
      "impact": "삭제된 History를 가리키는 restore_profile 잔존",
      "mitigation": "History 삭제 시 연관 restore_profile 경고 표시 (즉시 삭제 불필요)"
    },
    {
      "id": "R-6",
      "risk": "document_fields.tableRows 미저장",
      "impact": "History 상세에서 품목표 재확인 불가 (현재 기능 누락)",
      "mitigation": "2A 설계 시 runSnapshot.documentFields에 포함 여부 결정 필요"
